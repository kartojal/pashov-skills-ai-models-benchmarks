{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Security Audit Benchmark Report",
  "type": "object",
  "required": ["metadata", "summary", "findings"],
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["model", "harness", "target", "timestamp", "duration_seconds", "skill_version"],
      "properties": {
        "model": { "type": "string", "description": "Model identifier (e.g. claude-opus-4.6)" },
        "harness": { "type": "string", "description": "AI coding tool (e.g. claude-code, opencode, codex)" },
        "target": { "type": "string", "description": "Target project name (e.g. notional-finance)" },
        "timestamp": { "type": "string", "format": "date-time" },
        "duration_seconds": { "type": "number" },
        "skill_version": { "type": "string" }
      }
    },
    "summary": {
      "type": "object",
      "required": ["total_findings", "critical", "high", "medium", "low", "informational"],
      "properties": {
        "total_findings": { "type": "integer" },
        "critical": { "type": "integer" },
        "high": { "type": "integer" },
        "medium": { "type": "integer" },
        "low": { "type": "integer" },
        "informational": { "type": "integer" }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "severity", "confidence", "description"],
        "properties": {
          "id": { "type": "string", "pattern": "^F-\\d+$" },
          "title": { "type": "string" },
          "severity": { "type": "string", "enum": ["critical", "high", "medium", "low", "informational"] },
          "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
          "category": { "type": "string" },
          "description": { "type": "string" },
          "location": {
            "type": "object",
            "properties": {
              "file": { "type": "string" },
              "lines": { "type": "string" }
            }
          },
          "recommendation": { "type": "string" },
          "agents_reporting": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "raw_output": { "type": "string", "description": "Raw markdown output from the audit skill" }
  }
}
